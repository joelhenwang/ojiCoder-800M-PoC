{
  "vocab_size": 64000,
  "max_position_embeddings": 8192,
  "num_hidden_layers": 24,
  "hidden_size": 1536,
  "intermediate_size": 4096,
  "num_attention_heads": 16,
  "num_key_value_heads": 4,
  "head_dim": 96,
  "rope_theta": 10000.0,
  "rms_norm_eps": 1e-6,
  "layer_scale_init": 0.1,
  "tie_word_embeddings": true,
  "use_qk_norm": true,
  "use_value_residual": true,
  "use_per_head_gating": true,
  "special_tokens": [
    "<|repo|>",
    "<|path|>",
    "<|file_sep|>",
    "<|diff|>",
    "<|tool_call|>",
    "<|tool_result|>",
    "<|memory|>",
    "<|plan|>",
    "<|patch|>"
  ]
}
